# Git で無視するファイルの設定
# 参考: https://help.github.com/articles/ignoring-files/

# 依存パッケージ
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# テスト関連
/coverage

# Next.js ビルド出力
/.next/
/out/

# 本番ビルド
/build

# その他
.DS_Store
*.pem

# デバッグログ
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 環境変数ファイル（必要に応じてコミット対象に含めてよい）
.env*

# Vercel デプロイ関連
.vercel

# TypeScript ビルド情報
*.tsbuildinfo
next-env.d.ts
